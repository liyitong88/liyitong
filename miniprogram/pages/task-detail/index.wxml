<view class="page" wx:if="{{task}}">
  <view class="top-hero">
    <view class="hero-orb"></view>
    <view class="hero-orb2"></view>
    <view class="hero-orb3"></view>
    <view class="hero-badge">{{task.dueBadge}}</view>
    <view class="hero-title">{{task.title}}</view>
    <view class="hero-subtitle">{{task.taskCode}} · {{task.department}} · {{task.owner}}</view>
    <view class="hero-chip-row">
      <text class="hero-chip">{{task.type}}</text>
      <text class="hero-chip ghost">{{task.status}}</text>
      <text class="hero-chip ghost">{{task.equipmentName || '未填设备'}}</text>
    </view>
    <view class="summary-band">
      <view class="summary-panel">
        <view class="summary-label">{{focusTitle}}</view>
        <view class="summary-value">{{focusNote}}</view>
        <view class="summary-sub">{{stats.createdAgo}} · {{stats.logCount}} 条记录</view>
      </view>
      <view class="summary-panel">
        <view class="summary-label">任务编号</view>
        <view class="summary-value">{{task.taskCode}}</view>
        <button class="btn-ghost" style="margin-top:14rpx;height:64rpx;" bindtap="copyTaskCode">复制编号</button>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">基本信息</view>
    <view class="tabs-inline" style="margin-bottom:14rpx;">
      <button class="pill" bindtap="goHome">首页</button>
      <button class="pill" bindtap="goTasks">任务列表</button>
      <button class="pill active">当前详情</button>
    </view>
    <view class="grid-2">
      <view class="stat"><view class="stat-label">任务类型</view><view class="stat-value" style="font-size:28rpx;">{{task.type}}</view></view>
      <view class="stat"><view class="stat-label">当前状态</view><view class="stat-value" style="font-size:28rpx;">{{task.status}}</view></view>
      <view class="stat"><view class="stat-label">设备名称</view><view class="stat-value" style="font-size:28rpx;">{{task.equipmentName || '-'}}</view></view>
      <view class="stat"><view class="stat-label">设备编号</view><view class="stat-value" style="font-size:28rpx;">{{task.equipmentCode || '-'}}</view></view>
      <view class="stat"><view class="stat-label">截止日期</view><view class="stat-value" style="font-size:28rpx;">{{task.dueDate || '-'}}</view></view>
      <view class="stat"><view class="stat-label">完成日期</view><view class="stat-value" style="font-size:28rpx;">{{task.finishDate || '-'}}</view></view>
    </view>
    <view class="section-subtitle" style="margin-top:16rpx;">问题描述</view>
    <view class="muted">{{task.description || '暂无'}}</view>
  </view>

  <view class="section-card">
    <view class="section-title">动作</view>
    <view class="section-subtitle">把最常用的处理动作放在前面。</view>
    <view class="grid-2">
      <button class="btn-primary" bindtap="openEdit">编辑任务</button>
      <button class="btn-ghost" bindtap="openComplete">完成闭环</button>
      <picker wx:if="{{statusOptions.length}}" mode="selector" range="{{statusOptions}}" value="{{statusIndex}}" bindchange="onStatusChange">
        <view class="picker-field">切换状态：{{task.status}} ▾</view>
      </picker>
      <view wx:else class="picker-field">当前状态不可直接切换</view>
      <button class="btn-ghost" bindtap="cancelTask">标记取消</button>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">处理记录</view>
    <view class="section-subtitle">{{stats.logCount}} 条记录 · {{stats.dueHint}}</view>
    <view class="field">
      <textarea class="textarea" value="{{logDraft}}" bindinput="onLogInput" placeholder="补充一条处理记录，例如：联系厂家、到场、换件等"></textarea>
    </view>
    <button class="btn-primary" bindtap="addLog">添加记录</button>
    <view class="timeline" style="margin-top:18rpx;">
      <view wx:if="{{logs.length}}">
        <view wx:for="{{logs}}" wx:key="id" class="timeline-item">
          <view class="task-title" style="font-size:28rpx;">{{item.logContent}}</view>
          <view class="task-meta">{{item.operator}} · {{item.logTime}}</view>
        </view>
      </view>
      <view wx:else class="empty">暂无处理记录。</view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">附件</view>
    <view class="section-subtitle">{{stats.attachmentCount}} 个附件 · 支持图片预览</view>
    <button class="btn-ghost" bindtap="chooseImage">上传图片</button>
    <view wx:if="{{attachments.length}}" style="margin-top:16rpx;">
      <view wx:for="{{attachments}}" wx:key="id" class="task-item" style="margin-bottom:12rpx;" data-path="{{item.filePath}}" bindtap="previewAttachment">
        <view class="task-title" style="font-size:28rpx;">{{item.fileName}}</view>
        <view class="muted">{{item.uploadedAt}}</view>
      </view>
    </view>
    <view wx:else class="empty">暂无附件。</view>
  </view>
</view>

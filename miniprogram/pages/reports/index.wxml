<view class="page">
  <view class="top-hero">
    <view class="hero-orb"></view>
    <view class="hero-orb2"></view>
    <view class="hero-orb3"></view>
    <view class="hero-badge">月度报告</view>
    <view class="hero-title">一键生成工作汇总</view>
    <view class="hero-subtitle">按时间范围统计新增、完成、超期、费用和重点事项。</view>
    <view class="hero-chip-row">
      <text class="hero-chip">本月汇总</text>
      <text class="hero-chip ghost">重点事项</text>
      <text class="hero-chip ghost">Excel 导出</text>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">时间范围</view>
    <view class="grid-2">
      <view class="field"><text class="field-label">开始日期</text><picker mode="date" value="{{range.start}}" bindchange="onStartChange"><view class="picker-field">{{range.start}} ▾</view></picker></view>
      <view class="field"><text class="field-label">结束日期</text><picker mode="date" value="{{range.end}}" bindchange="onEndChange"><view class="picker-field">{{range.end}} ▾</view></picker></view>
    </view>
    <button class="btn-primary" bindtap="generate">生成报告</button>
  </view>

  <view wx:if="{{summary}}" class="section-card">
    <view class="section-title">{{summary.title}}</view>
    <view class="section-subtitle">{{summary.headline}}</view>
    <view class="report-hero">
      <view class="report-hero-title">本期概览</view>
      <view class="report-hero-text">{{reportLead}}</view>
    </view>
    <view class="report-grid" style="margin-top:16rpx;">
      <view wx:for="{{reportCards}}" wx:key="label" class="report-panel">
        <view class="report-label">{{item.label}}</view>
        <view class="report-value">{{item.value}}</view>
      </view>
    </view>
    <view class="section-subtitle" style="margin-top:16rpx;">任务类型分布</view>
    <view class="task-tags">
      <text wx:for="{{typeRows}}" wx:key="name" class="tag">{{item.name}} {{item.value}}</text>
    </view>
    <view class="section-subtitle" style="margin-top:16rpx;">科室分布</view>
    <view class="task-tags">
      <text wx:for="{{deptRows}}" wx:key="name" class="tag">{{item.name}} {{item.value}}</text>
    </view>
    <view class="section-subtitle" style="margin-top:16rpx;">重点事项</view>
    <view class="timeline">
      <view wx:if="{{summary.stats.important.length}}">
        <view wx:for="{{summary.stats.important}}" wx:key="*this" class="timeline-item">
          <view class="task-title" style="font-size:28rpx;">{{item}}</view>
        </view>
      </view>
      <view wx:else class="empty">暂无重点事项。</view>
    </view>
    <view class="grid-2" style="margin-top:10rpx;">
      <button class="btn-ghost" bindtap="copyReport">复制报告文本</button>
      <button class="btn-primary" loading="{{loading}}" bindtap="exportExcel">导出 Excel</button>
    </view>
  </view>

  <view wx:if="{{reportText}}" class="section-card">
    <view class="section-title">报告正文</view>
    <view class="muted" style="white-space:pre-wrap;">{{reportText}}</view>
  </view>
</view>

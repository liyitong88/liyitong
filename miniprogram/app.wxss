page {
  background:
    radial-gradient(circle at 20% 10%, rgba(20, 184, 166, 0.16), transparent 26%),
    radial-gradient(circle at 85% 0%, rgba(29, 78, 216, 0.14), transparent 22%),
    linear-gradient(180deg, #eff6ff 0%, #f8fafc 46%, #eef2ff 100%);
  color: #0f172a;
  font-size: 30rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  padding-bottom: env(safe-area-inset-bottom);
}

view,
text,
scroll-view,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  line-height: 1;
  color: inherit;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
}

.top-hero {
  position: relative;
  overflow: hidden;
  border-radius: 36rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  color: #fff;
  background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 48%, #14b8a6 100%);
  box-shadow: 0 24rpx 56rpx rgba(15, 23, 42, 0.16);
}

.top-hero::after {
  content: "";
  position: absolute;
  inset: auto -20% -40% auto;
  width: 280rpx;
  height: 280rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.12), transparent 70%);
  pointer-events: none;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.15;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 25rpx;
  line-height: 1.6;
}

.planet-card {
  position: relative;
  margin-top: 26rpx;
  min-height: 220rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(15, 23, 42, 0.16);
  overflow: hidden;
}

.planet-ring {
  position: absolute;
  inset: 20rpx;
  border-radius: 28rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.22);
}

.planet-orbit {
  position: absolute;
  width: 260rpx;
  height: 260rpx;
  right: -40rpx;
  top: -50rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  background: radial-gradient(circle at 35% 35%, rgba(255,255,255,0.16), transparent 40%);
}

.planet-core {
  position: relative;
  z-index: 1;
  display: grid;
  gap: 10rpx;
  align-content: center;
  min-height: 220rpx;
  padding: 28rpx 30rpx;
}

.planet-title {
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.planet-note {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
}

.mission-strip {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.mission-tile {
  padding: 18rpx 14rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  text-align: center;
}

.mission-value {
  font-size: 34rpx;
  font-weight: 800;
}

.mission-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
}

.hero-orb,
.hero-orb2,
.hero-orb3 {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  animation: drift 9s ease-in-out infinite;
}

.hero-orb {
  width: 220rpx;
  height: 220rpx;
  right: -80rpx;
  top: -60rpx;
}

.hero-orb2 {
  width: 140rpx;
  height: 140rpx;
  right: 36rpx;
  bottom: -50rpx;
  animation-delay: -2s;
}

.hero-orb3 {
  width: 76rpx;
  height: 76rpx;
  left: 58rpx;
  bottom: 24rpx;
  animation-delay: -4s;
}

.section-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  border-radius: 30rpx;
  box-shadow: 0 18rpx 42rpx rgba(15, 23, 42, 0.08);
  padding: 24rpx;
  margin-bottom: 22rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 800;
}

.section-subtitle {
  color: #64748b;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.stat {
  border-radius: 24rpx;
  padding: 22rpx 18rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.92));
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.06);
}

.stat-label {
  color: #64748b;
  font-size: 24rpx;
}

.stat-value {
  margin-top: 10rpx;
  font-size: 42rpx;
  font-weight: 800;
}

.stat-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  color: #fff;
  font-weight: 700;
  background: linear-gradient(135deg, #2563eb, #14b8a6);
}

.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: #0f172a;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(148, 163, 184, 0.24);
}

.btn-danger {
  color: #fff;
  background: linear-gradient(135deg, #ef4444, #f97316);
}

.filter-bar {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  font-size: 24rpx;
}

.pill.active {
  color: #fff;
  background: linear-gradient(135deg, #1d4ed8, #14b8a6);
  border-color: transparent;
}

.task-item {
  padding: 22rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 252, 0.94));
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  margin-bottom: 16rpx;
}

.task-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.task-title {
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.task-meta,
.muted {
  color: #64748b;
  font-size: 24rpx;
}

.task-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 14rpx;
}

.tag {
  display: inline-flex;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.1);
  color: #1d4ed8;
  font-size: 22rpx;
}

.tag.warn {
  background: rgba(245, 158, 11, 0.16);
  color: #b45309;
}

.tag.danger {
  background: rgba(239, 68, 68, 0.16);
  color: #b91c1c;
}

.tag.success {
  background: rgba(20, 184, 166, 0.16);
  color: #0f766e;
}

.hero-chip-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.hero-chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
}

.hero-chip.ghost {
  background: rgba(255, 255, 255, 0.08);
}

.summary-band {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 16rpx;
  margin-top: 12rpx;
}

.summary-panel {
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}

.summary-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.74);
}

.summary-value {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.summary-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.76);
}

.report-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.report-panel {
  padding: 18rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(248, 250, 252, 0.94), rgba(255, 255, 255, 0.98));
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.report-label {
  color: #64748b;
  font-size: 22rpx;
}

.report-value {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.report-hero {
  display: grid;
  gap: 12rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(29, 78, 216, 0.1), rgba(20, 184, 166, 0.08));
  border: 1rpx solid rgba(29, 78, 216, 0.1);
}

.report-hero-title {
  font-size: 30rpx;
  font-weight: 800;
}

.report-hero-text {
  color: #475569;
  font-size: 24rpx;
  line-height: 1.7;
}

.profile-hero-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.profile-hero-tile {
  padding: 16rpx 12rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  text-align: center;
}

.profile-hero-value {
  font-size: 30rpx;
  font-weight: 800;
}

.profile-hero-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
}

.sync-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 8rpx;
}

.sync-state {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.6;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.field {
  margin-bottom: 18rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #475569;
  font-size: 24rpx;
}

.input,
.textarea,
.picker-field {
  width: 100%;
  border-radius: 22rpx;
  padding: 20rpx 22rpx;
  background: #fff;
  border: 1rpx solid rgba(148, 163, 184, 0.24);
  font-size: 28rpx;
}

.textarea {
  min-height: 180rpx;
}

.footer-actions {
  position: sticky;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 18rpx 0 6rpx;
  background: linear-gradient(180deg, rgba(239, 246, 255, 0), rgba(239, 246, 255, 0.96) 24%, rgba(239, 246, 255, 1));
}

@keyframes drift {
  0%,
  100% {
    transform: translate3d(0, 0, 0) scale(1);
  }
  50% {
    transform: translate3d(0, -14rpx, 0) scale(1.03);
  }
}

.timeline {
  padding-left: 14rpx;
}

.timeline-item {
  position: relative;
  padding: 0 0 24rpx 28rpx;
}

.timeline-item::before {
  content: "";
  position: absolute;
  left: 0;
  top: 10rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #1d4ed8;
  box-shadow: 0 0 0 8rpx rgba(29, 78, 216, 0.12);
}

.timeline-item::after {
  content: "";
  position: absolute;
  left: 7rpx;
  top: 26rpx;
  bottom: 0;
  width: 2rpx;
  background: rgba(100, 116, 139, 0.2);
}

.timeline-item:last-child::after {
  display: none;
}

.tabs-inline {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.empty {
  text-align: center;
  padding: 60rpx 24rpx;
  color: #64748b;
}

.sticky-search {
  position: sticky;
  top: 0;
  z-index: 2;
  padding: 12rpx 0 18rpx;
  backdrop-filter: blur(14rpx);
}
